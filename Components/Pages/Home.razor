@page "/"
@rendermode InteractiveServer
@implements IDisposable
@inject GameRoomService Rooms
@inject GameEngine Engine

<PageTitle>TransTrans</PageTitle>

<div class="shell">
    <header class="app-header">
        <div>
            <h1>TransTrans</h1>
            <p>ルームコードで2人対戦できる錬成カードゲーム</p>
        </div>
        <div class="header-actions">
            <button class="secondary" @onclick="ToggleAlchemyTree">錬成ツリー</button>
            @if (room is not null)
            {
                <div class="room-tools">
                    <button class="secondary" @onclick="LeaveRoom">戻る</button>
                    <div class="room-badge">
                        <span>Room</span>
                        <strong>@room.Code</strong>
                    </div>
                </div>
            }
        </div>
    </header>

    @if (showAlchemyTree)
    {
        <section class="tree-overlay">
            <div class="tree-panel">
                <div class="tree-header">
                    <div>
                        <h2>錬成ツリー</h2>
                        <p>すべての錬成物、素材、研究コスト、効果を確認できます。</p>
                    </div>
                    <div class="tree-controls">
                        <input @bind="treeSearch" @bind:event="oninput" placeholder="素材名で検索" />
                        <button class="secondary" @onclick="ToggleAlchemyTree">閉じる</button>
                    </div>
                </div>
                <div class="tree-grid">
                    @foreach (var research in FilteredResearches())
                    {
                        <article class="tree-item @RankClass(research.Rank)">
                            <h3>@research.Name</h3>
                            <p>@research.RankText</p>
                            <p><strong>素材:</strong> @research.RecipeText</p>
                            <p><strong>研究コスト:</strong> @research.Cost</p>
                            <p><strong>効果:</strong> @(string.IsNullOrWhiteSpace(research.Description) ? "なし" : research.Description)</p>
                        </article>
                    }
                </div>
            </div>
        </section>
    }

    @if (room is null)
    {
        <section class="lobby">
            <div class="lobby-panel">
                <h2>対戦を始める</h2>
                <div class="lobby-actions">
                    <button class="primary" @onclick="CreateRoom">ルーム作成</button>
                    <div class="join-row">
                        <input @bind="joinCode" placeholder="ルームコード" maxlength="4" />
                        <button @onclick="JoinRoom">参加</button>
                    </div>
                </div>
                @if (!string.IsNullOrWhiteSpace(status))
                {
                    <p class="status">@status</p>
                }
            </div>
        </section>
    }
    else
    {
        var game = room.State;
        var me = game.Player(playerNumber);
        var opponent = game.Opponent(playerNumber);
        var isCurrent = game.CurrentPlayerNumber == playerNumber;
        var pendingForMe = game.PendingChoice?.PlayerNumber == playerNumber;
        var selectedResearch = SelectedResearch(game);

        <section class="game-status">
            <div>
                <span>あなた</span>
                <strong>Player @playerNumber</strong>
            </div>
            <div>
                <span>現在のターン</span>
                <strong>Turn @game.Turn / @game.CurrentPlayer.Name</strong>
            </div>
            <div>
                <span>状態</span>
                <strong>@(isCurrent ? "あなたの番" : "相手の番")</strong>
            </div>
            <div class="log latest-log">@game.Log</div>
        </section>

        @if (game.WinnerPlayerNumber is not null)
        {
            <section class="victory-panel">
                <h2>Player @game.WinnerPlayerNumber の勝利</h2>
                <p>@game.WinReason</p>
            </section>
        }

        @if (game.PendingChoice is not null)
        {
            <section class="choice-panel @(pendingForMe ? "active" : "")">
                <div>
                    <h2>@game.PendingChoice.Message</h2>
                    <p>@(pendingForMe ? "選択してください。" : "相手の選択待ちです。")</p>
                </div>
                @if (pendingForMe)
                {
                    <div class="choice-list">
                        @if (game.PendingChoice.Kind == PendingChoiceKind.SecondPlayerStartingElement)
                        {
                            @foreach (var element in Elements)
                            {
                                <button @onclick="() => PlaceStartingElement(element)">@ElementName(element)</button>
                            }
                        }
                        @foreach (var choice in ChoiceCards(game))
                        {
                            <button @onclick="() => ResolveChoice(choice.Id)">@choice.Name</button>
                        }
                        @foreach (var choice in ChoiceResearches(game))
                        {
                            <button @onclick="() => ResolveChoice(choice.Id)">
                                @choice.Name
                                <small>@choice.RankText / @choice.RecipeText</small>
                            </button>
                        }
                        @if (game.PendingChoice.Kind is not PendingChoiceKind.RevealResearch
                            and not PendingChoiceKind.SecondPlayerStartingElement)
                        {
                            <button class="ghost" @onclick="CancelChoice">キャンセル</button>
                        }
                    </div>
                }
            </section>
        }

        <section class="board">
            <aside class="panel">
                <h2>相手</h2>
                <div class="meter">
                    <span>エリクサー</span>
                    <strong>@opponent.Elixir</strong>
                </div>
                <div class="card-grid compact">
                    @foreach (var card in opponent.Hand)
                    {
                        <div class="card opponent-card">
                            <strong>@card.Name</strong>
                        </div>
                    }
                </div>
            </aside>

            <main class="center-board">
                <section class="panel cauldron @EnvironmentClass(game.Cauldron.Environment)">
                    <div class="panel-title">
                        <h2>共通大釜</h2>
                        <span>@EnvironmentText(game.Cauldron.Environment)</span>
                    </div>
                    <div class="cauldron-counts">
                        <span>火 @ElementCount(game, ElementType.Fire)</span>
                        <span>水 @ElementCount(game, ElementType.Water)</span>
                        <span>風 @ElementCount(game, ElementType.Air)</span>
                        <span>土 @ElementCount(game, ElementType.Earth)</span>
                    </div>
                    <div class="card-grid">
                        @foreach (var card in game.Cauldron.Cards)
                        {
                            <div class="card cauldron-card @(card.IsReady ? "ready" : "aging") @CardRankClass(card)">
                                <strong>@card.Name</strong>
                                <small>@(card.IsReady ? "熟成済み" : "未熟成")</small>
                            </div>
                        }
                    </div>
                </section>

                <section class="panel gather">
                    <h2>採取</h2>
                    <div class="button-grid">
                        @foreach (var element in Elements)
                        {
                            <button disabled="@(!CanAct)" @onclick="() => Take(element)">
                                @ElementName(element)
                                <small>@Engine.GetGatherCost(game, element)</small>
                            </button>
                        }
                    </div>
                </section>
            </main>

            <aside class="panel">
                <h2>あなた</h2>
                <div class="meter">
                    <span>エリクサー</span>
                    <strong>@me.Elixir</strong>
                </div>
                <div class="card-grid hand">
                    @foreach (var card in me.Hand)
                    {
                        <div class="card hand-card @(card.CanPutIntoCauldron ? "clickable" : "") @CardRankClass(card)"
                             title="@(card.CanPutIntoCauldron ? "クリックで大釜に入れる" : "")"
                             @onclick="() => OnHandCardClicked(card)">
                            <strong>@card.Name</strong>
                            <small>@CardTypeText(card)</small>
                            @if (card.CanUse)
                            {
                                <button disabled="@(!CanAct)" @onclick="() => Use(card.Id)" @onclick:stopPropagation>使用</button>
                            }
                            else if (card is AlchemyItem { Rank: AlchemyRank.UpperComposite, HasBeenUsed: true })
                            {
                                <small class="used-label">使用済み</small>
                            }
                        </div>
                    }
                </div>
                <button class="end-turn" disabled="@(!CanAct)" @onclick="EndTurn">ターン終了</button>
            </aside>
        </section>

        <section class="research-area">
            <div class="panel action-log">
                <h2>操作ログ</h2>
                <div class="log-list">
                    @foreach (var entry in game.LogEntries)
                    {
                        <p>@entry</p>
                    }
                </div>
            </div>

            <div class="panel research-panel">
                <h2>研究可能</h2>
                <div class="research-list">
                    @foreach (var research in Engine.AvailableResearches(game, playerNumber))
                    {
                        <article class="research @RankClass(research.Rank)">
                            <h3>@research.Name</h3>
                            <p>@research.RankText / @research.RecipeText</p>
                            <p>@research.Description</p>
                            <button disabled="@(!CanAct)" @onclick="() => Research(research.Id)">
                                研究 @Engine.GetResearchCost(game, research)
                            </button>
                        </article>
                    }
                </div>
            </div>

            <div class="panel">
                <h2>錬成可能</h2>
                <div class="tag-list">
                    @foreach (var research in Engine.CraftableResearches(game, playerNumber))
                    {
                        <button class="tag-button" disabled="@(!CanAct)" @onclick="() => Craft(research.Id)">
                            @research.Name
                        </button>
                    }
                </div>
            </div>

            <div class="panel">
                <h2>研究済み</h2>
                <div class="tag-list">
                    @foreach (var research in me.ResearchDeck.Where(x => x.IsUnlocked))
                    {
                        <button class="tag-button @(selectedResearchId == research.Id ? "selected" : "")"
                                @onclick="() => SelectResearch(research.Id)">
                            @research.Name@(research.IsSealed(game.Turn) ? "【封印中】" : "")
                        </button>
                    }
                </div>
            </div>

            <div class="panel detail-panel">
                <h2>研究詳細</h2>
                @if (selectedResearch is null)
                {
                    <p class="muted">研究済みの研究をクリックすると素材を確認できます。</p>
                }
                else
                {
                    <h3>@selectedResearch.Name</h3>
                    <p>@selectedResearch.RankText</p>
                    <p><strong>素材:</strong> @selectedResearch.RecipeText</p>
                    @if (!string.IsNullOrWhiteSpace(selectedResearch.Description))
                    {
                        <p>@selectedResearch.Description</p>
                    }
                }
            </div>
        </section>
    }
</div>

@code {
    private static readonly ElementType[] Elements =
    [
        ElementType.Fire,
        ElementType.Water,
        ElementType.Air,
        ElementType.Earth
    ];

    private GameRoom? room;
    private int playerNumber;
    private string joinCode = "";
    private string status = "";
    private Guid? selectedResearchId;
    private bool showAlchemyTree;
    private string treeSearch = "";

    private bool CanAct =>
        room is not null &&
        room.State.CurrentPlayerNumber == playerNumber &&
        room.State.WinnerPlayerNumber is null &&
        room.State.PendingChoice is null;

    private void CreateRoom()
    {
        room = Rooms.CreateRoom();
        playerNumber = Rooms.Join(room);
        Subscribe();
        status = "";
    }

    private void JoinRoom()
    {
        var target = Rooms.GetRoom(joinCode);
        if (target is null)
        {
            status = "ルームが見つかりません。";
            return;
        }

        var seat = Rooms.Join(target);
        if (seat == 0)
        {
            status = "そのルームは満席です。";
            return;
        }

        room = target;
        playerNumber = seat;
        Subscribe();
        status = "";
    }

    private void LeaveRoom()
    {
        if (room is not null)
        {
            room.Changed -= OnRoomChanged;
        }

        room = null;
        playerNumber = 0;
        selectedResearchId = null;
        status = "";
    }

    private void ToggleAlchemyTree() => showAlchemyTree = !showAlchemyTree;

    private static IEnumerable<ResearchCard> AllResearches() => ResearchCatalog.CreateDeck();

    private IEnumerable<ResearchCard> FilteredResearches()
    {
        var query = treeSearch.Trim();
        return string.IsNullOrWhiteSpace(query)
            ? AllResearches()
            : AllResearches().Where(x => x.Recipe.Any(material =>
                material.Contains(query, StringComparison.OrdinalIgnoreCase)));
    }

    private void Subscribe()
    {
        if (room is not null)
        {
            room.Changed += OnRoomChanged;
        }
    }

    private void OnRoomChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private void Take(ElementType element) => Engine.TakeElement(room!, playerNumber, element);
    private void PutIntoCauldron(Guid cardId) => Engine.PutIntoCauldron(room!, playerNumber, cardId);
    private void OnHandCardClicked(Card card)
    {
        if (card.CanPutIntoCauldron && CanAct)
        {
            PutIntoCauldron(card.Id);
        }
    }

    private void Research(Guid researchId) => Engine.Research(room!, playerNumber, researchId);
    private void Craft(Guid researchId) => Engine.Craft(room!, playerNumber, researchId);
    private void Use(Guid itemId) => Engine.UseItem(room!, playerNumber, itemId);
    private void EndTurn() => Engine.EndTurn(room!, playerNumber);
    private void PlaceStartingElement(ElementType element) => Engine.PlaceStartingElement(room!, playerNumber, element);
    private void ResolveChoice(Guid selectedId) => Engine.ResolveChoice(room!, playerNumber, selectedId);
    private void CancelChoice() => Engine.CancelChoice(room!, playerNumber);
    private void SelectResearch(Guid researchId) => selectedResearchId = researchId;

    private ResearchCard? SelectedResearch(GameState game)
    {
        return selectedResearchId is null
            ? null
            : game.Player(playerNumber).ResearchDeck.FirstOrDefault(x => x.Id == selectedResearchId);
    }

    private IEnumerable<Card> ChoiceCards(GameState game)
    {
        var pending = game.PendingChoice;
        if (pending is null)
        {
            return [];
        }

        return pending.Kind switch
        {
            PendingChoiceKind.ThunderSteal => game.Opponent(playerNumber).Hand.Where(x => pending.CandidateIds.Contains(x.Id)),
            PendingChoiceKind.MossAge => game.Cauldron.Cards.Where(x => pending.CandidateIds.Contains(x.Id)),
            _ => []
        };
    }

    private IEnumerable<ResearchCard> ChoiceResearches(GameState game)
    {
        var pending = game.PendingChoice;
        if (pending is null)
        {
            return [];
        }

        return pending.Kind switch
        {
            PendingChoiceKind.RevealResearch
                or PendingChoiceKind.ClayCreate
                or PendingChoiceKind.PotteryCreate
                => game.Player(playerNumber).ResearchDeck.Where(x => pending.CandidateIds.Contains(x.Id)),
            PendingChoiceKind.ObsidianSeal
                => game.Opponent(playerNumber).ResearchDeck.Where(x => pending.CandidateIds.Contains(x.Id)),
            _ => []
        };
    }

    private static int ElementCount(GameState game, ElementType element) =>
        game.Cauldron.Cards.OfType<ElementCard>().Count(x => x.Element == element);

    private static string ElementName(ElementType element) => element switch
    {
        ElementType.Fire => "火",
        ElementType.Water => "水",
        ElementType.Air => "風",
        ElementType.Earth => "土",
        _ => ""
    };

    private static string EnvironmentText(EnvironmentType env) => env switch
    {
        EnvironmentType.Fire => "火環境",
        EnvironmentType.Water => "水環境",
        EnvironmentType.Air => "風環境",
        EnvironmentType.Earth => "土環境",
        _ => "通常環境"
    };

    private static string EnvironmentClass(EnvironmentType env) => env switch
    {
        EnvironmentType.Fire => "environment-fire",
        EnvironmentType.Water => "environment-water",
        EnvironmentType.Air => "environment-air",
        EnvironmentType.Earth => "environment-earth",
        _ => "environment-none"
    };

    private static string CardRankClass(Card card) =>
        card is AlchemyItem item ? RankClass(item.Rank) : "";

    private static string RankClass(AlchemyRank rank) => rank switch
    {
        AlchemyRank.LowerComposite or AlchemyRank.LowerPurification => "rank-lower",
        AlchemyRank.MiddlePurification => "rank-middle",
        AlchemyRank.UpperComposite or AlchemyRank.UpperPurification or AlchemyRank.PhilosopherStone => "rank-upper",
        _ => ""
    };

    private static string CardTypeText(Card card) => card switch
    {
        ElementCard element => ElementName(element.Element),
        AlchemyItem item => item.Rank switch
        {
            AlchemyRank.LowerComposite => "下級複合",
            AlchemyRank.UpperComposite => "上級複合",
            AlchemyRank.LowerPurification => "下級純化",
            AlchemyRank.MiddlePurification => "中級純化",
            AlchemyRank.UpperPurification => "上級純化",
            _ => item.Rank.ToString()
        },
        _ => ""
    };

    public void Dispose()
    {
        if (room is not null)
        {
            room.Changed -= OnRoomChanged;
        }
    }
}
